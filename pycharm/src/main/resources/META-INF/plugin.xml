<idea-plugin>
    <id>com.scadwright.pycharm</id>
    <name>SCADwright</name>
    <version>0.1.0</version>
    <vendor>scadwright-local</vendor>

    <description><![CDATA[
        <p>Editor-toolbar actions for working with <a href="https://github.com/brianssparetime/SCADwright">scadwright</a>
        Python scripts:</p>
        <ul>
            <li><b>Preview</b> — build the active script and open the resulting <code>.scad</code> in OpenSCAD.</li>
            <li><b>Render</b> — build the active script and render to STL via headless OpenSCAD.</li>
            <li><b>Kill OpenSCAD</b> — stop any running OpenSCAD process.</li>
        </ul>
        <p>Phase 1: actions only. Phase 2 will add equation-language highlighting and completion
        inside <code>equations = """..."""</code> blocks.</p>
    ]]></description>

    <change-notes><![CDATA[
        <h3>0.1.0</h3>
        <ul>
            <li>Initial release. Three editor-toolbar actions (Preview / Render / Kill OpenSCAD)
            and a Settings → Tools → SCADwright pane mirroring the VSCode extension's options.</li>
        </ul>
    ]]></change-notes>

    <depends>com.intellij.modules.platform</depends>
    <depends>com.intellij.modules.python</depends>

    <extensions defaultExtensionNs="com.intellij">
        <applicationService
            serviceImplementation="com.scadwright.settings.ScadwrightSettings"/>
        <applicationConfigurable
            parentId="tools"
            instance="com.scadwright.settings.ScadwrightSettingsConfigurable"
            id="com.scadwright.settings"
            displayName="SCADwright"/>
    </extensions>

    <actions>
        <action id="scadwright.preview"
                class="com.scadwright.actions.PreviewAction"
                text="SCADwright: Preview in OpenSCAD"
                description="Build the active scadwright script and open in OpenSCAD"
                icon="/icons/preview.svg">
            <add-to-group group-id="MainToolbarRight" anchor="last"/>
            <add-to-group group-id="EditorPopupMenu" anchor="last"/>
            <add-to-group group-id="ToolsMenu" anchor="last"/>
        </action>
        <action id="scadwright.render"
                class="com.scadwright.actions.RenderAction"
                text="SCADwright: Render to STL"
                description="Build the active scadwright script and render to STL"
                icon="/icons/render.svg">
            <add-to-group group-id="MainToolbarRight" anchor="last"/>
            <add-to-group group-id="EditorPopupMenu" anchor="last"/>
            <add-to-group group-id="ToolsMenu" anchor="last"/>
        </action>
        <action id="scadwright.kill"
                class="com.scadwright.actions.KillAction"
                text="SCADwright: Kill OpenSCAD"
                description="Stop any running OpenSCAD process"
                icon="/icons/kill.svg">
            <add-to-group group-id="MainToolbarRight" anchor="last"/>
            <add-to-group group-id="EditorPopupMenu" anchor="last"/>
            <add-to-group group-id="ToolsMenu" anchor="last"/>
        </action>
    </actions>
</idea-plugin>
