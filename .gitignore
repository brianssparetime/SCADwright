*~

# VSCode extension build artifacts (the extension source lives in `vscode/`;
# these are produced by `vsce package`, `npm install`, or running the
# extension under VSCode's test runner — none of them belong in the repo).
vscode/node_modules/
vscode/*.vsix
vscode/.vscode-test/
vscode/out/

# PyCharm/IntelliJ plugin build artifacts. The plugin source lives in
# `pycharm/`; these are produced by `./gradlew build`, `runIde`, or the
# Gradle daemon — none of them belong in the repo.
pycharm/.gradle/
pycharm/build/
pycharm/out/
pycharm/*.iml

# Jupyter
.ipynb_checkpoints/
